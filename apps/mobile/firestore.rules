rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signup: anyone can read handles to check availability; only authenticated users can create (reserve) a handle
    match /handles/{handleId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Landing waitlist: anyone can add (create only); no read/update/delete from client
    match /mailingList/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'source', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.source in ['hero', 'cta'];
      allow read, update, delete: if false;
    }

    // Users: any signed-in user can read any user doc (for profiles, suggested users)
    match /users/{userId} {
      allow read, write: if request.auth != null;
      match /saved_lists/{listId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // Followers: any signed-in user can read (to show on profile); create/delete when you're the follower
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerId;
      }
      // Following: any signed-in user can read (to show on profile); write only your own
      match /following/{followingId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
      match /activity_feed/{feedId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Lists: any signed-in user can read/write (for profile lists, collaboration)
    match /lists/{listId} {
      allow read, write: if request.auth != null;
      match /items/{itemId} {
        allow read, write: if request.auth != null;
        match /reactions/{reactionId} {
          allow read, write: if request.auth != null;
        }
        match /event_rsvp/{userId} {
          allow read, write: if request.auth != null;
        }
        match /comments/{commentId} {
          allow read, write: if request.auth != null;
        }
      }
      match /activity/{activityId} {
        allow read, write: if request.auth != null;
      }
      match /collaborators/{collaboratorId} {
        allow read, write: if request.auth != null;
      }
    }

    // Collection-group queries on `event_rsvp` (e.g. Discover global attendance) must match this
    // path pattern explicitly; nested rules alone can still yield PERMISSION_DENIED for collectionGroup().
    match /{path=**}/event_rsvp/{rsvpUserId} {
      allow read, write: if request.auth != null;
    }

    // Admin-managed collections: public read, write only for admin users
    // Admin users have role 'admin' or 'superadmin' in users/{uid}
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Artist can be written by admin or by the owning user (userId matches)
    function isArtistOwner(artistId) {
      return request.auth != null
        && get(/databases/$(database)/documents/artists/$(artistId)).data.userId == request.auth.uid;
    }
    match /artists/{artistId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isArtistOwner(artistId);
    }

    // Experience (event/special) can be written by admin or by artist owner
    function isExperienceArtistOwner(experienceId) {
      let exp = get(/databases/$(database)/documents/experiences/$(experienceId));
      return exp.data.artistId != null
        && request.auth != null
        && get(/databases/$(database)/documents/artists/$(exp.data.artistId)).data.userId == request.auth.uid;
    }
    function isNewExperienceArtistOwner() {
      return request.resource.data.artistId != null
        && request.auth != null
        && get(/databases/$(database)/documents/artists/$(request.resource.data.artistId)).data.userId == request.auth.uid;
    }
    match /experiences/{experienceId} {
      allow read: if true;
      allow create: if isAdmin() || isNewExperienceArtistOwner();
      allow update, delete: if isAdmin() || isExperienceArtistOwner(experienceId);
    }

    // ExperienceInstance can be written by admin or by artist owner (instance has artistId)
    function isInstanceArtistOwner(instanceId) {
      let inst = get(/databases/$(database)/documents/experienceInstances/$(instanceId));
      return inst.data.artistId != null
        && request.auth != null
        && get(/databases/$(database)/documents/artists/$(inst.data.artistId)).data.userId == request.auth.uid;
    }
    function isNewInstanceArtistOwner() {
      return request.resource.data.artistId != null
        && request.auth != null
        && get(/databases/$(database)/documents/artists/$(request.resource.data.artistId)).data.userId == request.auth.uid;
    }
    match /experienceInstances/{instanceId} {
      allow read: if true;
      allow create: if isAdmin() || isNewInstanceArtistOwner();
      allow update, delete: if isAdmin() || isInstanceArtistOwner(instanceId);
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.author.userId == request.auth.uid;
        allow delete: if request.auth != null
          && (resource.data.author.userId == request.auth.uid || isAdmin());
        allow update: if false;
      }
    }

    match /venues/{venueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // DEVELOPMENT RULES - Allows all access
    // ⚠️ WARNING: These rules allow anyone to read/write your database
    // Only use for development/testing!
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
