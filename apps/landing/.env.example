# Copy to .env.local and fill in. Get values from Mailchimp → Audience → Signup forms → Embedded forms.

# Full form action URL (the form's action attribute)
VITE_MAILCHIMP_FORM_ACTION=

# Honeypot field name (e.g. b_XXXXXXXX_YYYYYYYY from the hidden input in the embed code)
VITE_MAILCHIMP_HIDDEN_FIELD=
