# Include devDependencies for monorepo builds when npm would otherwise omit them
# (e.g. global `npm config set omit dev`, or production-style install defaults).
include=dev

# Do NOT set omit=optional. Tailwind CSS v4 (via @tailwindcss/postcss) depends on
# lightningcss optionalDependencies such as lightningcss-linux-x64-gnu on Vercel;
# omitting optional breaks `next build` with "Cannot find module lightningcss.linux-x64-gnu.node".
